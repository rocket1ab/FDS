! ══ ① 高热流可燃面测点（壁温 + 净热流）══

! ══ ② 舱段气相环境测点（前/中/后 ×2 高度）══
&DEVC ID='T_fore_breath', QUANTITY='TEMPERATURE', XYZ=2.30,-0.10,0.80 /
&DEVC ID='T_fore_head', QUANTITY='TEMPERATURE', XYZ=2.30,-0.10,1.40 /
&DEVC ID='O2_fore',  QUANTITY='VOLUME FRACTION', SPEC_ID='OXYGEN', XYZ=2.30,-0.10,0.8 /
&DEVC ID='CO_fore',  QUANTITY='VOLUME FRACTION', SPEC_ID='CARBON MONOXIDE', XYZ=2.30,-0.10,0.8 /
&DEVC ID='VIS_fore', QUANTITY='VISIBILITY', XYZ=2.30,-0.10,0.8 /
&DEVC ID='T_mid_breath', QUANTITY='TEMPERATURE', XYZ=4.90,-0.10,0.80 /
&DEVC ID='T_mid_head', QUANTITY='TEMPERATURE', XYZ=4.90,-0.10,1.40 /
&DEVC ID='O2_mid',  QUANTITY='VOLUME FRACTION', SPEC_ID='OXYGEN', XYZ=4.90,-0.10,0.8 /
&DEVC ID='CO_mid',  QUANTITY='VOLUME FRACTION', SPEC_ID='CARBON MONOXIDE', XYZ=4.90,-0.10,0.8 /
&DEVC ID='VIS_mid', QUANTITY='VISIBILITY', XYZ=4.90,-0.10,0.8 /
&DEVC ID='T_aft_breath', QUANTITY='TEMPERATURE', XYZ=7.50,-0.10,0.80 /
&DEVC ID='T_aft_head', QUANTITY='TEMPERATURE', XYZ=7.50,-0.10,1.40 /
&DEVC ID='O2_aft',  QUANTITY='VOLUME FRACTION', SPEC_ID='OXYGEN', XYZ=7.50,-0.10,0.8 /
&DEVC ID='CO_aft',  QUANTITY='VOLUME FRACTION', SPEC_ID='CARBON MONOXIDE', XYZ=7.50,-0.10,0.8 /
&DEVC ID='VIS_aft', QUANTITY='VISIBILITY', XYZ=7.50,-0.10,0.8 /

! ══ ③ 全域指标 ══
&DEVC ID='HRR_total', QUANTITY='HRR', XB=-0.250,10.050,-1.850,1.650,-2.150,2.550 /
&DEVC ID='LAYER_fore', QUANTITY='LAYER HEIGHT', XB=2.30,2.30,-0.10,-0.10,-2.150,2.550 /
&DEVC ID='LAYER_mid', QUANTITY='LAYER HEIGHT', XB=4.90,4.90,-0.10,-0.10,-2.150,2.550 /
&DEVC ID='LAYER_aft', QUANTITY='LAYER HEIGHT', XB=7.50,7.50,-0.10,-0.10,-2.150,2.550 /
&DEVC ID='O2_min_global', QUANTITY='VOLUME FRACTION', SPEC_ID='OXYGEN', SPATIAL_STATISTIC='MIN', XB=-0.250,10.050,-1.850,1.650,0.4,1.6 /

! ══ ④ SLCF 观测平面 ══
&SLCF PBY=-0.10, QUANTITY='TEMPERATURE' /        ! 中纵剖面
&SLCF PBY=-0.10, QUANTITY='HRRPUV' /
&SLCF PBY=-0.10, QUANTITY='VOLUME FRACTION', SPEC_ID='OXYGEN' /
&SLCF PBX=1.78, QUANTITY='TEMPERATURE' /          ! cockpit 横截面
&SLCF PBX=4.90, QUANTITY='TEMPERATURE' /          ! mid 横截面
&SLCF PBX=8.02, QUANTITY='TEMPERATURE' /          ! aft 横截面
&SLCF PBZ=0.80, QUANTITY='TEMPERATURE' /                  ! 呼吸层
&SLCF PBZ=0.80, QUANTITY='VOLUME FRACTION', SPEC_ID='OXYGEN' /
&SLCF PBZ=0.80, QUANTITY='VOLUME FRACTION', SPEC_ID='CARBON MONOXIDE' /

! ══ ⑤ BNDF 边界场 ══
&BNDF QUANTITY='WALL TEMPERATURE' /
&BNDF QUANTITY='NET HEAT FLUX' /
&BNDF QUANTITY='BURNING RATE' /


! ══════════════════════════════════════════════════════════
! 设备毁伤监测探针（按材料分类，供双重判据后处理）
! 每个探针 ID 对应一种材料 → 一套临界温度/耐受时间判据
! ══════════════════════════════════════════════════════════
! ── 材料: E-玻璃纤维 → 判据[equipment/雷达罩] 部件=雷达罩 T_crit=200℃ τ=45s ──
&DEVC ID='D_0_0_RADM_WT', QUANTITY='WALL TEMPERATURE', XYZ=-0.025000,0.000000,0.000000, IOR=-1 /
&DEVC ID='D_0_0_RADM_HF', QUANTITY='NET HEAT FLUX', XYZ=-0.025000,0.000000,0.000000, IOR=-1 /
&DEVC ID='D_0_1_RADM_WT', QUANTITY='WALL TEMPERATURE', XYZ=0.075000,0.000000,-0.250000, IOR=-1 /
&DEVC ID='D_0_1_RADM_HF', QUANTITY='NET HEAT FLUX', XYZ=0.075000,0.000000,-0.250000, IOR=-1 /
